{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Auth Service",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/AuthService/CapFinLoan.Auth.API/CapFinLoan.Auth.API.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true
    },
    {
      "label": "Start Application Service",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/ApplicationService/CapFinLoan.Application.API/CapFinLoan.Application.API.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true
    },
    {
      "label": "Start Admin Service",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/AdminService/CapFinLoan.Admin.API/CapFinLoan.Admin.API.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true
    },
    {
      "label": "Start Document Service",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/DocumentService/CapFinLoan.Document.API/CapFinLoan.Document.API.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true
    },
    {
      "label": "Start API Gateway",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/ApiGateway/CapFinLoan.Gateway.API/CapFinLoan.Gateway.API.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true
    },
    {
      "label": "Start All Services",
      "dependsOn": [
        "Start Auth Service",
        "Start Application Service",
        "Start Admin Service",
        "Start Document Service",
        "Start API Gateway"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
