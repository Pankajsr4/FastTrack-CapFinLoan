{
  "Routes": [
    {
      "UpstreamPathTemplate": "/gateway/auth/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS" ],
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [ { "Host": "auth-service", "Port": 8080 } ],
      "SwaggerKey": "auth"
    },
    {
      "UpstreamPathTemplate": "/gateway/applications/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS" ],
      "DownstreamPathTemplate": "/api/applications/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [ { "Host": "application-service", "Port": 8080 } ],
      "AuthenticationOptions": { "AuthenticationProviderKey": "Bearer" },
      "SwaggerKey": "applications"
    },
    {
      "UpstreamPathTemplate": "/gateway/documents/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS" ],
      "DownstreamPathTemplate": "/api/documents/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [ { "Host": "document-service", "Port": 8080 } ],
      "AuthenticationOptions": { "AuthenticationProviderKey": "Bearer" },
      "SwaggerKey": "documents"
    },
    {
      "UpstreamPathTemplate": "/gateway/hubs/notifications/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "OPTIONS" ],
      "DownstreamPathTemplate": "/hubs/notifications/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [ { "Host": "notification-service", "Port": 8080 } ]
    },
    {
      "UpstreamPathTemplate": "/gateway/hubs/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "OPTIONS" ],
      "DownstreamPathTemplate": "/hubs/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [ { "Host": "document-service", "Port": 8080 } ]
    },
    {
      "UpstreamPathTemplate": "/gateway/admin/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS" ],
      "DownstreamPathTemplate": "/api/admin/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [ { "Host": "admin-service", "Port": 8080 } ],
      "AuthenticationOptions": { "AuthenticationProviderKey": "Bearer" },
      "SwaggerKey": "admin"
    },
    {
      "UpstreamPathTemplate": "/gateway/notifications/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
      "DownstreamPathTemplate": "/api/notifications/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [ { "Host": "notification-service", "Port": 8080 } ]
    },
    {
      "UpstreamPathTemplate": "/gateway/ai/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "OPTIONS" ],
      "DownstreamPathTemplate": "/api/ai/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [ { "Host": "ai-assistant-service", "Port": 8080 } ]
    },
    {
      "UpstreamPathTemplate": "/gateway/internal/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "PATCH" ],
      "DownstreamPathTemplate": "/api/internal/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [ { "Host": "document-service", "Port": 8080 } ],
      "AuthenticationOptions": { "AuthenticationProviderKey": "Bearer" }
    }
  ],
  "SwaggerEndPoints": [
    {
      "Key": "auth",
      "TransformByOcelotConfig": true,
      "Config": [ { "Name": "Auth Service",        "Version": "v1", "Url": "http://auth-service:8080/swagger/v1/swagger.json" } ]
    },
    {
      "Key": "applications",
      "TransformByOcelotConfig": true,
      "Config": [ { "Name": "Application Service", "Version": "v1", "Url": "http://application-service:8080/swagger/v1/swagger.json" } ]
    },
    {
      "Key": "documents",
      "TransformByOcelotConfig": true,
      "Config": [ { "Name": "Document Service",    "Version": "v1", "Url": "http://document-service:8080/swagger/v1/swagger.json" } ]
    },
    {
      "Key": "admin",
      "TransformByOcelotConfig": true,
      "Config": [ { "Name": "Admin Service",       "Version": "v1", "Url": "http://admin-service:8080/swagger/v1/swagger.json" } ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5000",
    "RequestIdKey": "X-Request-Id"
  }
}
