### ============================================================
### 3. DOCUMENT SERVICE — Upload a document
### POST /api/documents/upload
### Content-Type: multipart/form-data
### ============================================================

# @name uploadDocument
POST {{docBase}}/api/documents/upload
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=----FormBoundary

------FormBoundary
Content-Disposition: form-data; name="applicationId"

{{applicationId}}
------FormBoundary
Content-Disposition: form-data; name="documentType"

NationalId
------FormBoundary
Content-Disposition: form-data; name="file"; filename="passport.pdf"
Content-Type: application/pdf

< ./sample-files/passport.pdf
------FormBoundary--

###
# Expected 200 response:
# {
#   "id":            "7c9e6679-7425-40de-944b-e07fc1f90ae7",
#   "applicationId": "00000000-0000-0000-0000-000000000001",
#   "userId":        "3fa85f64-5717-4562-b3fc-2c963f66afa6",
#   "fileName":      "passport.pdf",
#   "contentType":   "application/pdf",
#   "fileSizeBytes": 145678,
#   "documentType":  "NationalId",
#   "status":        "Pending",
#   "isVerified":    false,
#   "failureReason": null,
#   "createdAtUtc":  "2026-04-02T10:15:00Z",
#   "updatedAtUtc":  "2026-04-02T10:15:00Z"
# }
#
# Expected 400 (unsupported file type):
# {
#   "success": false,
#   "errors": ["File type is not supported. Allowed types: PDF, JPG, PNG."]
# }
#
# Expected 400 (file too large):
# {
#   "success": false,
#   "errors": ["File size exceeds the maximum allowed size of 5 MB."]
# }


