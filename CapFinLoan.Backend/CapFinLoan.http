### ============================================================
### CapFinLoan Backend — API Test Requests
### Compatible with: VS Code REST Client, JetBrains HTTP Client
###
### Variables — change these to match your running services
### ============================================================

@authBase     = http://localhost:5021
@appBase      = http://localhost:5022
@docBase      = http://localhost:5023
@adminBase    = http://localhost:5024

### Paste the token returned by Login below (no "Bearer " prefix)
@token        = REPLACE_WITH_JWT_TOKEN

### IDs — fill in after creating resources
@applicationId = 00000000-0000-0000-0000-000000000001
@documentId    = 00000000-0000-0000-0000-000000000002


### ============================================================
### 1. AUTH SERVICE — User Signup
### POST /api/auth/register
### ============================================================

# @name signup
POST {{authBase}}/api/auth/register
Content-Type: application/json

{
  "firstName": "Jane",
  "lastName":  "Doe",
  "email":     "jane.doe@example.com",
  "password":  "SecurePass123!",
  "role":      "Applicant"
}

###
# Expected 200 response:
# {
#   "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
#   "expiresAt": "2026-04-03T10:00:00Z",
#   "user": {
#     "id":        "3fa85f64-5717-4562-b3fc-2c963f66afa6",
#     "email":     "jane.doe@example.com",
#     "firstName": "Jane",
#     "lastName":  "Doe",
#     "role":      "Applicant"
#   }
# }


